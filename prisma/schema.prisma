generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  schemas   = ["auth", "public"]
}

model Session {
  id                  String    @id(map: "session_de_pkey") @default(cuid())
  shop                String    @unique
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime? @db.Timestamp(6)
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime? @db.Timestamp(6)

  @@map("Session_de")
  @@schema("public")
}

model Settings_de {
  id            String   @id(map: "settings_de_pkey") @default(cuid())
  shop          String   @unique
  taxPercentage Float
  carrierCharge Float
  updatedAt     DateTime @updatedAt @db.Timestamp(6)
  usdToEuroRate Float

  @@schema("public")
}

model ProductMapping_de {
  id               String   @id(map: "productmapping_de_pkey") @default(cuid())
  shop             String
  sku              String
  ingramPartNumber String
  createdAt        DateTime @default(now()) @db.Timestamp(6)
  updatedAt        DateTime @default(now()) @updatedAt @db.Timestamp(6)
  price            Decimal? @db.Decimal

  @@unique([shop, sku], map: "ProductMapping_de_shopDomain_sku_idx")
  @@index([shop], map: "ProductMapping_de_shopDomain_idx")
  @@schema("public")
}

model shopify_products_final_Germany {
  id                             BigInt                 @id @default(autoincrement())
  title                          String?
  body_html                      String?
  handle                         String?
  vendor                         String?
  product_type                   String?
  tags                           String?
  images                         Json?
  sku                            String                 @unique
  inventory_management           String?
  inventory_quantity             Int?
  price                          Decimal?               @db.Decimal
  compare_at_price               Decimal?               @db.Decimal
  barcode                        String?
  specs_table                    String?
  information                    String?
  created_at                     DateTime?              @default(now()) @db.Timestamptz(6)
  part_number                    String?
  source_type                    String?
  seo_title                      String?
  seo_description                String?
  embedding                      Unsupported("vector")?
  is_external_embedding_finished Boolean?

  @@index([embedding])
  @@schema("public")
}

model ProductSyncJob_de {
  id         String    @id(map: "productsyncjob_de_pkey")
  shop       String
  status     String
  processed  Int       @default(0)
  total      Int       @default(0)
  error      String?
  createdAt  DateTime  @default(now()) @db.Timestamp(6)
  updatedAt  DateTime  @default(now()) @updatedAt @db.Timestamp(6)
  finishedAt DateTime? @db.Timestamp(6)
  cursorSku  String?

  @@index([status])
  @@index([createdAt])
  @@index([shop])
  @@map("ProductSyncJob_de")
  @@schema("public")
}

model ShippingCalculationLog_de {
  id            String   @id(map: "shippingcalculationlog_de_pkey") @default(cuid())
  shop          String
  sku           String
  basePrice     Float
  taxAmount     Float
  carrierCharge Float
  total         Float
  status        String
  error         String?
  createdAt     DateTime @default(now()) @db.Timestamp(6)

  @@schema("public")
}

